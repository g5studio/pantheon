# Pantheon Cursor 環境變數配置
# 複製此檔案為 .env.local 並填入實際值

# ========================================
# Jira / Confluence API 配置
# ========================================
# Jira/Confluence 帳號 email
JIRA_EMAIL=

# Jira API Token（從 https://id.atlassian.com/manage-profile/security/api-tokens 取得）
JIRA_API_TOKEN=

# ========================================
# GitLab API 配置
# ========================================
# GitLab Personal Access Token（從 GitLab Settings > Access Tokens 取得）
GITLAB_TOKEN=

# ========================================
# Compass API 配置（選填）
# ========================================
# Compass API Token
COMPASS_API_TOKEN=

# ========================================
# LLM / OpenAI（選填）
# ========================================
# OpenAI API Key（用於 adapt / label-analyzer 的 LLM 推導；未設定會自動降級為 no-llm）
OPENAI_API_KEY=

# ========================================
# MR 配置
# ========================================
# 預設 MR Reviewer（GitLab username，如 @william.chiang）
MR_REVIEWER=

# ========================================
# Label Analyzer（選填）
# ========================================
# 為避免大變更（大量檔案 / 大型 diff）在 label 推導階段因緩衝區限制中斷（ENOBUFS / maxBuffer），
# label-analyzer 會先評估 diff 規模，只有在「小變更」才抓完整 patch。
#
# 允許抓 patch 的最大檔案數（預設 80）
LABEL_ANALYZER_MAX_PATCH_FILES=80
#
# 允許抓 patch 的最大新增+刪除行數總和（預設 2000）
LABEL_ANALYZER_MAX_PATCH_LINES=2000
#
# 抓 patch 時 execSync 的 maxBuffer（bytes，預設 50MB）
LABEL_ANALYZER_PATCH_MAX_BUFFER_BYTES=52428800

# ========================================
# Agent 個性化署名（選填）
# ========================================
# 自動留言末尾署名用的 agent 顯示名稱（建議 <= 40；未設定則不顯示署名）
AGENT_DISPLAY_NAME=
