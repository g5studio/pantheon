# Pantheon Cursor 環境變數配置
# 複製此檔案為 .env.local 並填入實際值
#
# 標記說明：
# - （必填）：多數 commit / MR / Jira 流程需要
# - （選填）：未設定時使用預設行為或關閉對應功能

# ========================================
# 必填
# ========================================
# 以下為多數 commit / MR / Jira 流程所需；請優先填寫

# Jira/Confluence 帳號 email
JIRA_EMAIL=

# Jira API Token（從 https://id.atlassian.com/manage-profile/security/api-tokens 取得）
JIRA_API_TOKEN=

# GitLab Personal Access Token（從 GitLab Settings > Access Tokens 取得）
GITLAB_TOKEN=

# ========================================
# 選填
# ========================================

# --- Reviewer Agent API ---
# AI review 與 Reviewer LLM provider 使用的 Reviewer API base URL
# Swagger：https://manageds-virtual-machine.balinese-python.ts.net/api/docs
# 預設：https://manageds-virtual-machine.balinese-python.ts.net
REVIEWER_AGENT_API_URL=

# Reviewer Agent API Token（AI review 需要；未設定則跳過 AI review）
REVIEWER_AGENT_API_TOKEN=

# --- Master Control Agent API ---
# 未設定時，Pantheon 自動 log 功能關閉（不影響 commit/MR 等主流程）
# Log API 完整 endpoint（POST）；request body 固定為 { "data": <payload> }
# 例：Ares 本機 http://localhost:8787/api/agent-logs
# llm-client 在 LLM 請求失敗（HTTP 4xx/5xx、network）或 JSON 解析失敗時會自動 POST；
# payload 含 action（任務名，如 start-task）、category=llm-error、
# JIRA_EMAIL、AGENT_DISPLAY_NAME、llmErrorCode、reason 等欄位。
MASTER_CONTROL_AGENT_API_URL=

# --- Communicator Agent / Hermes API ---
# 僅 COMMUNICATOR_AGENT_API_URL 未設定時，LINE WORKS 通知功能關閉（不影響 commit/MR 等主流程）
# Swagger：https://manageds-virtual-machine.balinese-python.ts.net/api/docs
COMMUNICATOR_AGENT_API_URL=

# Bearer token；未設定時使用 Pantheon 內建 shared token
COMMUNICATOR_AGENT_API_TOKEN=

# LINE WORKS 發送目標（對應 POST /api/v1/lineworks/messages 的 target）
# 未設定時會以 JIRA_EMAIL 查 GET /api/v1/company-members 取得 lineworks ID 並寫入 .cursor/.env.local
COMMUNICATOR_AGENT_TARGET=

# 通知末尾「點擊此處返回」deeplink 的慣用 editor
# 預設：cursor
# 支援：cursor | vscode | codex | claude-code | none（不附加返回連結）
# claude-code 別名：claude、claude-cli（deeplink：claude-cli://open?cwd=...）
COMMUNICATOR_RETURN_EDITOR=

# 通知正文 LLM 使用共用 OPENAI_API_KEY / CUSTOM_OPENAI_API_URL（內建預設 model：gpt-5.4-nano；失敗時 fallback 原文）

# --- LLM / OpenAI 共用 ---
# OpenAI API Key；未設定時多數工具改走 CUSTOM_OPENAI_API_URL
OPENAI_API_KEY=

# OpenAI-compatible API Domain
# 預設：http://service-hub-ai.balinese-python.ts.net/v1
CUSTOM_OPENAI_API_URL=http://service-hub-ai.balinese-python.ts.net/v1

# 各工具 LLM 預設 model 由程式內建，不開放 env 覆寫；必要時請使用各 CLI 的 --llm-model / --model

# --- Figma（prometheus 使用） ---
# Figma Access Token（用於 start-task / figma 相關工具）
FIGMA_ACCESS_TOKEN=

# --- Adapt ---
# adapt LLM provider 主要透過 CLI --llm-provider 指定
# 未設定 OPENAI_API_KEY 時預設走 CUSTOM_OPENAI_API_URL；compass 需顯式指定 provider

# --- Evolve ---
# evolve annotation-audit / schema 的 LLM provider
# 預設：auto（有 OPENAI_API_KEY 則 openai，否則 api-domain）
# 可設：auto | openai | api-domain
EVOLVE_LLM_PROVIDER=

# --- Label Analyzer ---
# MR label 推導 LLM provider；設 compass 時走 Reviewer operator-proxy
# 預設：未設定（依 OPENAI_API_KEY / CUSTOM_OPENAI_API_URL 自動選路）
LABEL_LLM_PROVIDER=

# 允許抓 patch 的最大檔案數
# 預設：80
LABEL_ANALYZER_MAX_PATCH_FILES=80

# 允許抓 patch 的最大新增+刪除行數總和
# 預設：2000
LABEL_ANALYZER_MAX_PATCH_LINES=2000

# 抓 patch 時 execSync 的 maxBuffer（bytes）
# 預設：52428800（50MB）
LABEL_ANALYZER_PATCH_MAX_BUFFER_BYTES=52428800

# --- Jira Content Formatter ---
# 設為 1 / true / yes 時跳過 Jira 留言格式檢查
# 預設：未設定（執行格式檢查）
JIRA_SKIP_FORMAT_CHECK=

# --- MR 配置 ---
# 預設 MR Reviewer（GitLab username，如 @william.chiang）
# 未設定時 create-mr 使用 @william.chiang
MR_REVIEWER=

# --- Agent 個性化署名 ---
# Communicator / Jira 留言末尾署名用的 agent 顯示名稱（建議 <= 40）
# 未設定則不顯示署名
AGENT_DISPLAY_NAME=
